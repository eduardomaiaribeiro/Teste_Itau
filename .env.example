# Insira os caminhos para o Java 8/11+ e o binário do Hadoop winutils (Apenas Windows)
JAVA_HOME=C:\Program Files\Java\jdk-17
HADOOP_HOME=C:\hadoop
# Utilize caminhos relativos ao invés de absolutos para facilitar a execução em outras máquinas
CLIENTS_PATH=data/clients/data.json
ORDERS_PATH=data/pedidos/data.json
APP_NAME=TesteTecnicoItauPySpark
SPARK_MASTER=local[*]
SPARK_DRIVER_HOST=127.0.0.1
SHOW_ROWS=20
LOG_LEVEL=ERROR